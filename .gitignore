# macOS
.DS_Store

# Xcode / build output
build/
DerivedData/
*.xcuserstate
*.xcuserdatad

# DMGs are distributed as GitHub Release assets, never committed
*.dmg

# Generated by xcodegen — recreate with `xcodegen generate`
ClipVault.xcodeproj/

# Sparkle download + heavy artifacts (the CLI tools in tools/sparkle/bin are kept)
tools/Sparkle.tar.xz
tools/sparkle/Sparkle.framework/
tools/sparkle/Symbols/
tools/sparkle/Sparkle Test App.app/
tools/sparkle/CHANGELOG
tools/sparkle/INSTALL
tools/sparkle/LICENSE
tools/sparkle/SampleAppcast.xml

# Never commit an exported private signing key (the key lives in your Keychain)
*_ed_priv
sparkle_private_key*
